[sub_resource type="GDScript" id="GDScript_5r8vm"]
script/source = "extends Control

var tentativas_falhas: int = 0
var limite_tentativas: int = 2
var senha_correta: String = \"admin123\"
var estah_bloqueado: bool = false

@onready var campo_senha   = %LineEditSenha
@onready var botao_entrar  = %Button
@onready var popup_alerta  = %AcceptDialog

func _ready() -> void:
	botao_entrar.pressed.connect(_ao_apertar_entrar)
	popup_alerta.confirmed.connect(_resetar_apos_lockdown)
	popup_alerta.canceled.connect(_resetar_apos_lockdown)

func _ao_apertar_entrar() -> void:
	if estah_bloqueado:
		return

	if campo_senha.text == senha_correta:
		# TODO: adicionar lógica de login bem-sucedido aqui
		pass
	else:
		tentativas_falhas += 1
		campo_senha.text = \"\"

		if tentativas_falhas >= limite_tentativas:
			_iniciar_lockdown_sistema()

func _iniciar_lockdown_sistema() -> void:
	estah_bloqueado        = true
	botao_entrar.disabled  = true
	botao_entrar.text      = \"Bloqueado\"
	campo_senha.editable   = false

	popup_alerta.title       = \"⚠️ CONTA SUSPENSA TEMPORARIAMENTE\"
	popup_alerta.dialog_text = (
		\"MEDIDA DE SEGURANÇA ATIVADA.\\n\\n\"
		+ \"Para garantir a privacidade das suas playlists e dados de assinatura, \"
		+ \"congelamos as tentativas neste dispositivo.\\n\\n\"
		+ \"Um link de verificação foi enviado ao e-mail do titular.\"
	)

	popup_alerta.popup_centered_clamped()

func _resetar_apos_lockdown() -> void:
	estah_bloqueado        = false
	botao_entrar.disabled  = false
	botao_entrar.text      = \"Entrar\"
	campo_senha.editable   = true
	tentativas_falhas      = 0
"

